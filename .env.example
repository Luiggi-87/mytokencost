# MyTokenCost Server Configuration
PORT=3001
NODE_ENV=development
DATABASE=./data/mytokencost.db

# Frontend API URL (production: set to backend URL)
VITE_API_URL=http://localhost:3001

# Authentication (change this to a strong secret in production)
JWT_SECRET=your-secret-key-change-this-in-production

# Stripe (opcional - deixar em branco para desativar)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Email (opcional - sem isso, o link de reset de senha é apenas logado no console)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# URL do frontend (usada para montar o link de "esqueci minha senha" no email)
FRONTEND_URL=http://localhost:3001

# Webhooks
WEBHOOK_RETRY_ATTEMPTS=3
WEBHOOK_TIMEOUT=5000
